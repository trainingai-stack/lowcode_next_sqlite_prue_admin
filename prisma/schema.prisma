
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "sqlite"
}

model Page {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?

  // 搭建数据 - 存储为 JSON 对象（包含组件数组）
  components  Json     @default("[]")

  // 元数据
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}
